
{
  "entities": {
    "UserProfile": {
      "title": "User Profile",
      "description": "Details about a MatchFlow user and their dating preferences.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "name": { "type": "string" },
        "gender": { "type": "string", "enum": ["male", "female"] },
        "dob": { "type": "string", "format": "date" },
        "country": { "type": "string" },
        "lookingFor": { "type": "string" },
        "educationLevel": { "type": "string" },
        "onboardingComplete": { "type": "boolean" },
        "photoURL": { "type": "string" },
        "createdAt": { "type": "object", "description": "Firestore Timestamp" },
        "updatedAt": { "type": "object", "description": "Firestore Timestamp" },
        "interests": { "type": "string" },
        "matchFlowId": { "type": "string", "description": "Unique 7-9 digit numeric ID." },
        "coins": { "type": "number", "description": "Currency for males to send messages." },
        "diamonds": { "type": "number", "description": "Currency for females earned from interactions." },
        "lastCheckInDate": { "type": "object", "description": "Firestore Timestamp of last check-in." },
        "checkInStreak": { "type": "number", "description": "Number of consecutive or cumulative check-in days (0-7)." },
        "blocking": { "type": "array", "items": { "type": "string" }, "description": "List of UIDs this user has blocked." },
        "blockedBy": { "type": "array", "items": { "type": "string" }, "description": "List of UIDs this user is blocked by." },
        "isVerified": { "type": "boolean" },
        "isDeleted": { "type": "boolean", "default": false },
        "isAdmin": { "type": "boolean", "default": false },
        "isCoinSeller": { "type": "boolean", "default": false }
      },
      "required": ["uid", "email", "onboardingComplete"]
    },
    "Chat": {
      "title": "Chat Room",
      "description": "A conversation between two users.",
      "type": "object",
      "properties": {
        "participants": { "type": "array", "items": { "type": "string" } },
        "createdAt": { "type": "object" },
        "updatedAt": { "type": "object" },
        "lastMessage": { "type": "string" },
        "lastMessageAt": { "type": "object" },
        "isDeleted": { "type": "boolean", "default": false }
      }
    },
    "Message": {
      "title": "Chat Message",
      "description": "An individual message within a chat room.",
      "type": "object",
      "properties": {
        "text": { "type": "string" },
        "senderId": { "type": "string" },
        "timestamp": { "type": "object" },
        "updatedAt": { "type": "object" }
      }
    }
  },
  "auth": {
    "providers": ["password"]
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "UserProfile",
      "description": "User profile data."
    },
    "/chats/{chatId}": {
      "schema": "Chat",
      "description": "Chat metadata."
    },
    "/chats/{chatId}/messages/{messageId}": {
      "schema": "Message",
      "description": "Messages in a specific chat."
    }
  }
}
