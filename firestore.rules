rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // User Profiles: Anyone logged in can read (for matching), but only the user can write their own document.
    match /users/{userId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    // Agencies: Authenticated users can read.
    match /agencies/{agencyCode} {
      allow read: if request.auth != null;
      allow write: if request.auth != null; // Logic is handled in server actions with isAgent check

      // Withdrawals: Specific to agency operations.
      match /withdrawals/{withdrawalId} {
        allow read, write: if request.auth != null;
      }
    }

    // Chats: Only participants of a chat can read, update, or delete it.
    match /chats/{chatId} {
      allow read, update, delete: if request.auth != null && request.auth.uid in resource.data.participants;
      allow create: if request.auth != null && request.auth.uid in request.resource.data.participants;
    }
  }
}