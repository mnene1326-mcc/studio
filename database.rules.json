{
  "rules": {
    /* Presence system: Anyone logged in can see who is online */
    "status": {
      ".read": "auth != null",
      "$uid": {
        ".write": "auth != null && auth.uid == $uid"
      }
    },
    /* Currency Balances: Only the owner can read or write their own balance */
    "balances": {
      "$uid": {
        ".read": "auth != null && auth.uid == $uid",
        ".write": "auth != null && auth.uid == $uid"
      }
    },
    /* Chat Messages: Authenticated users can read/write to chat rooms */
    "chat_messages": {
      "$chatId": {
        ".read": "auth != null",
        ".write": "auth != null"
      }
    },
    /* Unread Counters: Owner reads their count; anyone can increment it when sending a message */
    "unreads": {
      "$uid": {
        ".read": "auth != null && auth.uid == $uid",
        ".write": "auth != null"
      }
    }
  }
}