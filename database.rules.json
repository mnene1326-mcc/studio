{
  "rules": {
    /* Hali ya hewa (Online/Offline status) */
    "status": {
      ".read": "auth != null",
      "$uid": {
        ".write": "auth != null && auth.uid == $uid"
      }
    },
    /* Salio la Coins na Diamonds - Ni mmiliki pekee anayeweza kusoma na kuandika */
    "balances": {
      "$uid": {
        ".read": "auth != null && auth.uid == $uid",
        ".write": "auth != null && auth.uid == $uid"
      }
    },
    /* Jumbe za Chat - Zinaruhusu watumiaji walioingia kusoma na kuandika */
    "chat_messages": {
      "$chatId": {
        ".read": "auth != null",
        ".write": "auth != null"
      }
    },
    /* Idadi ya jumbe ambazo hazijasomwa (Unread counters) */
    "unreads": {
      "$uid": {
        ".read": "auth != null && auth.uid == $uid",
        // Mtu yeyote anaweza kuongeza kaunta ya unread anapotuma ujumbe
        ".write": "auth != null"
      }
    }
  }
}